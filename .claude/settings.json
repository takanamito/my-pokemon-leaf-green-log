{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "直前の応答にバトル（トレーナー戦・野生戦）の終了が含まれているか確認してください。バトル終了が含まれない場合、または含まれていて「【次のバトル準備】」フォーマットが出力されている場合はOKです。バトル終了が含まれるのにフォーマットが欠けている場合はNGで、理由は「【次のバトル準備】フォーマットを出力してください」です。",
            "model": "haiku"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/statusline.sh"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true
  }
}
